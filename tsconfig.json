{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020","DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@components/*": ["components/*"],
      "@context/*": ["context/*"],
      "@hooks/*": ["hooks/*"],
      "@utils/*": ["utils/*"],
      "@assets/*": ["assets/*"],
      "@styles/*": ["styles/*"],
      "@api/*": ["infrastructure/api/*"],
      "@store/*": ["store/*"],
      "@pages/*": ["pages/*"],
      "@db/*": ["db/*"],
      "@core": ["core/*"],
      "@types/*": ["types/*"]
    }
  },
  "include": ["src", "types"]
}